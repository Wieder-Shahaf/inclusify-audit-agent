# Offline-first: large data + local stores never committed
data/eric/*
!data/eric/.gitkeep
.chroma/
qdrant_storage/
models/
*.sqlite3

# Runtime artifacts that can capture a live endpoint URL / auth header — never commit
traces/
*.trace.json
logs/
*.log
.cache/
tests/cassettes/
*.cassette.yaml

# Secrets (none required in dev; never commit)
.env
.env.local

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/
dist/
build/
*.egg-info/

# OS
.DS_Store

# Claude session memory (local context, not a project artifact)
memory/

# Claude Code per-machine settings (local allowlists, personal preferences)
.claude/settings.local.json
