# All optional — the agent runs fully offline with the defaults below (no API keys).
# Provide real values only to switch from mock/local to live providers.

# LLM: mock (default, deterministic) | azure
LLM_PROVIDER=mock
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Embeddings: hash (default, fully offline) | local_st (sentence-transformers, one-time download) | azure
EMBEDDINGS_PROVIDER=hash
# AZURE_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# Vector store: chroma (local, no key)
VECTOR_STORE=chroma
CHROMA_PATH=.chroma

# Agent bounds
AGENT_MAX_ITERS=12
