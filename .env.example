# All optional — the agent runs fully offline with the defaults below (no API keys).
# Provide real values only to switch from mock/local to live providers.

# LLM: mock (default, deterministic) | azure | openai_compat (vLLM / any OpenAI-compatible endpoint)
LLM_PROVIDER=mock
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# openai_compat (e.g. vLLM serving Gemma): base URL + key + model
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# Embeddings: hash (default, fully offline) | local_st (sentence-transformers, one-time download) | azure | openai_compat
EMBEDDINGS_PROVIDER=hash
# AZURE_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small
# EMBEDDINGS_BASE_URL=
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_MODEL=

# Vector store: chroma (local, no key) | inmemory | qdrant | pinecone
VECTOR_STORE=chroma
CHROMA_PATH=.chroma
# qdrant (live): scripts/teardown_vm.sh deletes ONLY this collection (or prefix) on teardown
# QDRANT_URL=
# QDRANT_API_KEY=
# QDRANT_COLLECTION=inclusify_eric
# QDRANT_COLLECTION_PREFIX=inclusify_
# pinecone (course vector DB): index dim must match the embedder (text-embedding-3-small -> 1536)
# PINECONE_API_KEY=
# PINECONE_INDEX=inclusify-eric
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# Persistence (run logging): null (default, no DB) | supabase (course primary DB)
PERSISTENCE_PROVIDER=null
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_TABLE=audit_runs

# --- Course live stack (LLMod.ai = OpenAI-compatible proxy) -------------------
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=<the course proxy base url, WITH the /v1 suffix (OpenAI SDK style)>
# LLM_API_KEY=<group LLMod.ai key>
# LLM_MODEL=MB5R2CF-azure/gpt-5.4-mini
# EMBEDDINGS_PROVIDER=openai_compat
# EMBEDDINGS_BASE_URL=<the course proxy host WITHOUT /v1 — the provider appends /v1/embeddings itself>
# EMBEDDINGS_API_KEY=<group LLMod.ai key>
# EMBEDDINGS_MODEL=MB5R2CF-azure/text-embedding-3-small
# EMBED_DIM=1536

# Agent bounds
AGENT_MAX_ITERS=12

# Live ERIC API fallback (keyless, api.ies.ed.gov): when local citation grounding
# scores below the floor, the agent fetches fresh ERIC abstracts instead of asking
# the user. Off by default (offline-first) — set to 1 to enable.
# ERIC_LIVE_SEARCH=1
